---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";
import { site } from "@/config/site";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects
    .filter((p) => p.data.professional)
    .map((project) => ({
      params: { id: project.id },
      props: { project },
    }));
}

const { project } = Astro.props;
const { data } = project;
---

<Layout
  title={`${data.title} — ${site.name}`}
  description={data.description}
>
  <Header />

  <main class="pt-28 pb-20">
    <div class="mx-auto max-w-4xl px-6">
      <!-- Back -->
      <a
        href="/#projects"
        class="inline-flex items-center gap-1.5 text-sm text-text-tertiary hover:text-text-primary transition-colors mb-8"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to projects
      </a>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class="text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200/50 rounded-full px-2.5 py-0.5">
            Client Project
          </span>
          <span class={`text-xs font-medium rounded-full px-2.5 py-0.5 ${
            data.status === "Live"
              ? "text-emerald-700 bg-emerald-50"
              : data.status === "Completed"
                ? "text-blue-700 bg-blue-50"
                : "text-text-tertiary bg-gray-100"
          }`}>
            {data.status}
          </span>
          <span class="text-xs text-text-tertiary bg-gray-50 rounded-full px-2.5 py-0.5">
            {data.category}
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary mb-4">
          {data.title}
        </h1>

        <p class="text-lg text-text-secondary leading-relaxed max-w-3xl">
          {data.description}
        </p>

        {/* CTA buttons */}
        {data.buttons && data.buttons.length > 0 && (
          <div class="flex flex-wrap gap-3 mt-6">
            {data.buttons.map((btn) =>
              btn.url ? (
                <a
                  href={btn.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`inline-flex items-center gap-2 text-sm font-medium rounded-xl px-5 py-2.5 transition-all ${
                    btn.style === "primary"
                      ? "bg-brand text-white hover:bg-brand-dark shadow-sm"
                      : "border border-border text-text-secondary hover:text-text-primary hover:bg-surface-alt"
                  }`}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  {btn.label}
                </a>
              ) : null
            )}
          </div>
        )}
      </div>

      {/* Tech stack */}
      {data.tech.length > 0 && (
        <div class="mb-10">
          <h2 class="text-sm font-semibold text-text-primary mb-3 uppercase tracking-wide">Technology</h2>
          <div class="flex flex-wrap gap-2">
            {data.tech.map((t: string) => (
              <span class="text-sm font-medium text-text-secondary bg-surface-alt border border-border-light rounded-lg px-3 py-1.5">
                {t}
              </span>
            ))}
          </div>
        </div>
      )}

      {/* Key features from markdown body */}
      {project.rendered?.html && (
        <div class="mb-12">
          <h2 class="text-sm font-semibold text-text-primary mb-3 uppercase tracking-wide">Key Features</h2>
          <div class="text-text-secondary leading-relaxed [&_li]:mb-2 [&_ul]:list-disc [&_ul]:pl-5 [&_strong]:text-text-primary [&_strong]:font-semibold">
            <Fragment set:html={project.rendered.html} />
          </div>
        </div>
      )}

      {/* Screenshots gallery */}
      {data.screenshots && data.screenshots.length > 0 && (
        <div>
          <h2 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wide">Screenshots</h2>
          <div class={`grid gap-4 ${
            data.category === "iOS Mobile Application"
              ? "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4"
              : "grid-cols-1 sm:grid-cols-2"
          }`}>
            {data.screenshots.map((src: string, i: number) => (
              <div class={`rounded-xl border border-border overflow-hidden bg-gray-50 ${
                data.category === "iOS Mobile Application" ? "" : "aspect-[16/10]"
              }`}>
                <img
                  src={src}
                  alt={`${data.title} screenshot ${i + 1}`}
                  class={`w-full h-full ${
                    data.category === "iOS Mobile Application"
                      ? "object-contain"
                      : "object-cover object-top"
                  }`}
                  loading="lazy"
                  width="800"
                  height="500"
                />
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
