---
import { trustedTech } from "@/config/site";
---

<section class="py-16 border-y border-border bg-surface-alt">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm text-text-tertiary mb-8 tracking-wide uppercase">
      Technologies I work with
    </p>
    <div class="flex flex-wrap justify-center gap-x-10 gap-y-4">
      {
        trustedTech.map((tech) => (
          <span class="text-lg font-medium text-text-secondary/70 hover:text-text-primary transition-colors">
            {tech}
          </span>
        ))
      }
    </div>
  </div>
</section>
