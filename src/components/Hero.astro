---
import { site } from "@/config/site";
---

<section class="relative min-h-screen flex items-center pt-20 pb-16">
  <div class="mx-auto max-w-6xl px-6 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Content -->
      <div class="order-2 lg:order-1">
        <!-- Availability Badge -->
        <div class="fade-up inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-3.5 py-1.5 mb-6">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
          </span>
          <span class="text-sm text-emerald-700 font-medium">{site.availability}</span>
        </div>

        <!-- Heading -->
        <h1 class="fade-up text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] text-text-primary mb-6">
          I build backends<br />
          <span class="text-brand">that scale.</span>
        </h1>

        <!-- Description -->
        <p class="fade-up text-lg text-text-secondary leading-relaxed max-w-xl mb-8">
          Backend Engineer with production experience building scalable REST APIs,
          transaction processing systems, and AI-powered products. Currently
          at Betorra — architecting backend services for a live gaming platform.
        </p>

        <!-- Stats -->
        <div class="fade-up flex gap-8 mb-10">
          <div>
            <div class="text-2xl font-bold text-text-primary">1+</div>
            <div class="text-sm text-text-tertiary">Years Experience</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary">6+</div>
            <div class="text-sm text-text-tertiary">Projects Shipped</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary">1,200+</div>
            <div class="text-sm text-text-tertiary">Games Integrated</div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="fade-up flex flex-wrap gap-4">
          <a
            href="#projects"
            class="inline-flex items-center gap-2 rounded-xl bg-brand px-6 py-3 text-base font-medium text-white shadow-lg shadow-brand/25 hover:bg-brand-dark transition-all hover:shadow-xl hover:shadow-brand/30"
          >
            View my work
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-6 py-3 text-base font-medium text-text-primary shadow-sm hover:bg-surface-alt transition-colors"
          >
            Get in touch
          </a>
          <a
            href={site.resumeUrl}
            download="Harsh_Jadav_Resume.pdf"
            class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-6 py-3 text-base font-medium text-text-secondary hover:text-text-primary hover:bg-surface-alt transition-colors"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Resume
          </a>
        </div>
      </div>

      <!-- Right: Photo -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="fade-up relative">
          <div class="w-64 h-64 sm:w-80 sm:h-80 rounded-3xl overflow-hidden border border-border shadow-2xl shadow-gray-200/50">
            <img
              src={site.avatar}
              alt={site.name}
              width="320"
              height="320"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          <!-- Decorative elements -->
          <div class="absolute -z-10 -top-4 -right-4 w-full h-full rounded-3xl bg-brand/5 border border-brand/10"></div>
          <div class="absolute -z-20 -top-8 -right-8 w-full h-full rounded-3xl bg-brand/[0.02] border border-brand/5"></div>
        </div>
      </div>
    </div>
  </div>
</section>
