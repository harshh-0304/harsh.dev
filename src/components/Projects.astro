---
import SectionHeading from "./SectionHeading.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);
const professional = allProjects.filter((p) => p.data.professional);
const personal = allProjects.filter((p) => !p.data.professional);
const personalFeatured = personal.filter((p) => p.data.featured);
const personalOthers = personal.filter((p) => !p.data.featured);
---

<section id="projects" class="py-16 lg:py-20 bg-surface-alt">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      label="Projects"
      title="Work I'm proud of"
      description="Real products solving real problems — from client work to personal builds."
    />

    <!-- Professional Projects -->
    {professional.length > 0 && (
      <div class="mb-16">
        <div class="fade-up flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-text-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            Professional Client Work
          </span>
          <span class="text-xs text-text-tertiary">Selected client work</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-6 stagger">
          {professional.map((project) => {
            const hasImage = project.data.image || (project.data.category === "iOS Mobile Application" && project.data.screenshots);
            return (
              <div class={`fade-up group rounded-2xl border border-border bg-white overflow-hidden hover:border-brand/20 hover:shadow-xl hover:shadow-brand/5 hover:-translate-y-1 transition-all duration-300 ${!hasImage ? "lg:col-span-2" : ""}`}>
                {/* Screenshot hero — mobile app vs web vs none */}
                {project.data.category === "iOS Mobile Application" && project.data.screenshots ? (
                  <div class="relative overflow-hidden bg-gradient-to-br from-gray-50 to-gray-100 aspect-[16/10] flex items-center justify-center gap-3 px-8 py-6">
                    {project.data.screenshots.slice(0, 3).map((src: string, i: number) => (
                      <div class={`relative rounded-xl overflow-hidden shadow-lg border border-gray-200 h-full w-auto transition-transform duration-500 ${i === 1 ? "group-hover:scale-[1.04] z-10" : "group-hover:scale-[1.02]"}`}>
                        <img
                          src={src}
                          alt={`${project.data.title} screen ${i + 1}`}
                          class="h-full w-auto object-contain"
                          loading="lazy"
                        />
                      </div>
                    ))}
                  </div>
                ) : project.data.image ? (
                  <div class="relative overflow-hidden bg-gray-50 aspect-[16/10]">
                    <img
                      src={project.data.image}
                      alt={`${project.data.title} screenshot`}
                      class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
                      loading="lazy"
                      width="800"
                      height="500"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                  </div>
                ) : null}

                <div class={`p-6 ${!hasImage ? "lg:p-8" : ""}`}>
                  {/* Badges */}
                  <div class="flex flex-wrap items-center gap-2 mb-3">
                    <span class="text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200/50 rounded-full px-2.5 py-0.5">
                      Professional Project
                    </span>
                    <span class={`text-xs font-medium rounded-full px-2.5 py-0.5 ${
                      project.data.status === "Live"
                        ? "text-emerald-700 bg-emerald-50"
                        : project.data.status === "Completed"
                          ? "text-blue-700 bg-blue-50"
                          : "text-text-tertiary bg-gray-100"
                    }`}>
                      {project.data.status}
                    </span>
                    <span class="text-xs text-text-tertiary bg-gray-50 rounded-full px-2.5 py-0.5">
                      {project.data.category}
                    </span>
                  </div>

                  <h3 class={`font-bold text-text-primary mb-2 ${!hasImage ? "text-2xl" : "text-xl"}`}>{project.data.title}</h3>

                  <p class={`text-text-secondary leading-relaxed mb-4 ${!hasImage ? "text-base max-w-3xl" : "text-sm"}`}>
                    {project.data.description}
                  </p>

                  {/* Problem / Solution for no-image cards */}
                  {!hasImage && project.data.problem && (
                    <div class="mb-5 grid sm:grid-cols-2 gap-4 max-w-3xl">
                      <div class="rounded-xl bg-surface-alt p-4">
                        <p class="text-xs font-medium text-text-tertiary uppercase tracking-wide mb-1">The Challenge</p>
                        <p class="text-sm text-text-secondary">{project.data.problem}</p>
                      </div>
                      {project.data.solution && (
                        <div class="rounded-xl bg-surface-alt p-4">
                          <p class="text-xs font-medium text-text-tertiary uppercase tracking-wide mb-1">The Solution</p>
                          <p class="text-sm text-text-secondary">{project.data.solution}</p>
                        </div>
                      )}
                    </div>
                  )}

                  {/* Tech badges */}
                  {project.data.tech.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mb-5">
                      {project.data.tech.map((t: string) => (
                        <span class="text-xs font-medium text-text-secondary bg-gray-100 rounded-md px-2 py-1">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}

                  {/* Buttons */}
                  {project.data.buttons && (
                    <div class="flex flex-wrap gap-3">
                      {project.data.buttons.map((btn) => {
                        const isInternal = btn.url?.startsWith("/");
                        return btn.url ? (
                          <a
                            href={btn.url}
                            {...(!isInternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                            class={`inline-flex items-center gap-1.5 text-sm font-medium rounded-lg px-4 py-2 transition-all ${
                              btn.style === "primary"
                                ? "bg-brand text-white hover:bg-brand-dark shadow-sm"
                                : "border border-border text-text-secondary hover:text-text-primary hover:bg-surface-alt"
                            }`}
                          >
                            {btn.label === "Visit Website" || btn.label === "Live Website" ? (
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                            ) : btn.label === "View Details" ? (
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            ) : null}
                            {btn.label}
                          </a>
                        ) : null;
                      })}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Personal / Side Projects -->
    {personal.length > 0 && (
      <div>
        <div class="fade-up flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-text-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            Personal Projects
          </span>
        </div>

        {/* Featured personal projects */}
        <div class="grid lg:grid-cols-2 gap-6 mb-8 stagger">
          {personalFeatured.map((project) => (
            <div class="fade-up group rounded-2xl border border-border bg-white p-6 lg:p-8 hover:border-brand/20 hover:shadow-xl hover:shadow-brand/5 hover:-translate-y-1 transition-all duration-300">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-medium text-brand bg-brand/5 rounded-full px-2.5 py-0.5">
                      Featured
                    </span>
                    <span class={`text-xs font-medium rounded-full px-2.5 py-0.5 ${
                      project.data.status === "Live"
                        ? "text-emerald-700 bg-emerald-50"
                        : "text-text-tertiary bg-gray-100"
                    }`}>
                      {project.data.status}
                    </span>
                  </div>
                  <h3 class="text-xl font-bold text-text-primary mb-1">{project.data.title}</h3>
                  <p class="text-sm text-text-tertiary">{project.data.category}</p>
                </div>
              </div>

              <p class="text-text-secondary text-sm leading-relaxed mb-5">
                {project.data.description}
              </p>

              {project.data.problem && (
                <div class="mb-5 rounded-xl bg-surface-alt p-4">
                  <p class="text-xs font-medium text-text-tertiary uppercase tracking-wide mb-1">The Challenge</p>
                  <p class="text-sm text-text-secondary">{project.data.problem}</p>
                </div>
              )}

              <div class="flex flex-wrap gap-1.5 mb-5">
                {project.data.tech.map((t: string) => (
                  <span class="text-xs font-medium text-text-secondary bg-gray-100 rounded-md px-2 py-1">
                    {t}
                  </span>
                ))}
              </div>

              <div class="flex gap-3">
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-brand hover:text-brand-dark transition-colors"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                    Live Demo
                  </a>
                )}
                {project.data.github && (
                  <a
                    href={project.data.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                    Source Code
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>

        {/* Other personal projects */}
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
          {personalOthers.map((project) => (
            <div class="fade-up rounded-2xl border border-border bg-white p-6 hover:border-brand/20 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-300">
              <div class="flex items-center gap-2 mb-3">
                <span class={`text-xs font-medium rounded-full px-2.5 py-0.5 ${
                  project.data.status === "Live"
                    ? "text-emerald-700 bg-emerald-50"
                    : "text-text-tertiary bg-gray-100"
                }`}>
                  {project.data.status}
                </span>
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-1">{project.data.title}</h3>
              <p class="text-xs text-text-tertiary mb-3">{project.data.category}</p>
              <p class="text-sm text-text-secondary leading-relaxed mb-4">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {project.data.tech.slice(0, 4).map((t: string) => (
                  <span class="text-xs text-text-secondary bg-gray-100 rounded-md px-2 py-0.5">
                    {t}
                  </span>
                ))}
              </div>
              <div class="flex gap-3">
                {project.data.url && (
                  <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-brand hover:text-brand-dark transition-colors">
                    Live Demo →
                  </a>
                )}
                {project.data.github && (
                  <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                    Source →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
