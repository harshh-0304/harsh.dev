---
import SectionHeading from "./SectionHeading.astro";
---

<section class="py-16 lg:py-20 bg-surface-alt">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      label="Testimonials"
      title="What people say"
      description="Feedback from clients and colleagues I've worked with."
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
      {
        [
          {
            quote: "Harsh delivered a solid backend that handled our complex multi-provider integration flawlessly. His attention to API design and documentation was impressive.",
            name: "Sunny",
            role: "Co-Founder, Betorra",
          },
          {
            quote: "Reliable, communicative, and technically strong. He understood our business requirements quickly and translated them into clean, working code.",
            name: "Raj",
            role: "Co-Founder, DubFlix",
          },
          {
            quote: "His backend work on the wallet and transaction system was production-grade from day one. Great understanding of data consistency and error handling.",
            name: "Tushar",
            role: "Tech Lead, DubFlix",
          },
        ].map((t) => (
          <div class="fade-up rounded-2xl border border-border bg-white p-6">
            <svg class="w-8 h-8 text-brand/20 mb-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-sm text-text-secondary leading-relaxed mb-4">{t.quote}</p>
            <div>
              <p class="text-sm font-semibold text-text-primary">{t.name}</p>
              <p class="text-xs text-text-tertiary">{t.role}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
