---
import { site, navigation } from "@/config/site";
---

<footer class="border-t border-border bg-surface-alt/50">
  <!-- CTA strip -->
  <div class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-xl font-bold text-text-primary">Have a project in mind?</h3>
        <p class="text-sm text-text-secondary mt-1">Let's build something great together.</p>
      </div>
      <div class="flex gap-3">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-lg bg-brand px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-brand-dark transition-colors"
        >
          Get in touch
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a
          href={site.resumeUrl}
          download="Harsh_Jadav_Resume.pdf"
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-white px-5 py-2.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Resume
        </a>
      </div>
    </div>
  </div>

  <!-- Footer content -->
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-8">
      <!-- Brand -->
      <div class="max-w-xs">
        <a href="/" class="text-lg font-semibold tracking-tight text-text-primary">
          {site.name}<span class="text-brand">.</span>
        </a>
        <p class="text-sm text-text-tertiary mt-2 leading-relaxed">
          Backend Engineer building scalable systems and full-stack applications for businesses.
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-14">
        <div>
          <p class="text-xs font-semibold text-text-primary uppercase tracking-wider mb-3">Navigation</p>
          <div class="flex flex-col gap-2">
            {
              navigation.map((item) => (
                <a
                  href={item.href}
                  class="text-sm text-text-tertiary hover:text-text-primary transition-colors"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold text-text-primary uppercase tracking-wider mb-3">Connect</p>
          <div class="flex flex-col gap-2">
            <a href={`mailto:${site.email}`} class="text-sm text-text-tertiary hover:text-text-primary transition-colors">Email</a>
            <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-text-tertiary hover:text-text-primary transition-colors">LinkedIn</a>
            <a href={site.github} target="_blank" rel="noopener noreferrer" class="text-sm text-text-tertiary hover:text-text-primary transition-colors">GitHub</a>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-border pt-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-text-tertiary">
        &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
      </p>
      <p class="text-xs text-text-tertiary">
        Built with Astro & Tailwind CSS
      </p>
    </div>
  </div>
</footer>
